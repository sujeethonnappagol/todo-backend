<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <section class="max-w-2xl mx-auto mt-10 p-6 bg-white rounded-lg shadow-md text-center">
        <h1 class="text-3xl font-bold ">Organise your tasks here</h1>
        <p>Lorem ipsum dolor sit, amet consectetur adipisicing elit.</p>
        <form action="/add" method="post" class="flex gap-2 mt-4  justify-center">
            <input name="title" type="text" class="border-2 border-gray-300 p-2 rounded-md focus:outline-none focus:ring-2 focus:ring-black-500" placeholder="Enter your task">
            <button class="bg-black text-white rounded-sm px-7 py-3">Add Task</button>
        </form>

        <div class="mt-19">
            <% todos.forEach(todo => { %>
                <div class="text-lg border border-gray-300 p-2 mt-2 rounded-md"><%= todo %></div>
            <% });  %>
        </div>

    </section>
</body>
</html>